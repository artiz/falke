# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git!

aws_region   = "eu-west-2"
project_name = "falke"
environment  = "prod"

# ECS resources
ecs_cpu    = 256  # 0.25 vCPU
ecs_memory = 1024 # MB

# === Trading ===
trading_mode  = "paper"
paper_balance = "500.0"

# === ML strategy ===
ml_model_path         = "research/mr_classifier_xgboost.onnx"
ml_win_prob_threshold = "0.55"   # min win probability to take a trade
ml_reversion_threshold = "0.10"  # min price % change pre-filter for ML scan

# === Market filters ===
ml_market_expiry_window_hours = "48.0"  # ML: trade markets expiring within N hours
mr_market_expiry_window_hours = "0.5"   # MR: 30 min window for higher volatility
min_liquidity_usd             = "1000.0"
ignored_topics                = ""

# === Wallet / live trading ===
polygon_rpc_url         = "https://polygon-bor-rpc.publicnode.com"
process_usdc_allowances = "false"   # set true once for a new wallet, then back to false

# === Risk / engine ===
trade_poll_interval_sec  = "1"
max_bet_usd              = "50.0"
max_open_positions       = "100"
cooldown_sec             = "600"
pnl_notify_threshold_usd = "50.0"
budget_brake_pct         = "25.0"   # pause if lost N% of starting balance
budget_brake_time_sec    = "0"      # 0 = manual restart required

# === Mean Reversion strategy ===
mean_reversion_threshold  = "0.10"  # min price % change to trigger a MR signal
mean_reversion_budget_pct = "0.25"  # 0.0 = ML only, 1.0 = MR only, 0.25 = 25% MR
trade_bet_usd             = "5.0"   # fixed bet size per MR/ML position (shared)

# === Testing / parameter sweep ===
testing_mode                 = "false"
mean_reversion_threshold_min = "0.10"
mean_reversion_threshold_max = "0.90"
trade_bet_usd_min            = "1.0"
trade_bet_usd_max            = "10.0"
ml_test_threshold_min        = "0.50"
ml_test_threshold_max        = "0.80"

# === Secrets (fill these in) ===
telegram_bot_token = "YOUR_BOT_TOKEN_HERE"
allowed_phones     = "+43XXXXXXXXXX"
# wallet_private_key is set manually in AWS Secrets Manager — do not put it here
