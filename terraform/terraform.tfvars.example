# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git!

aws_region   = "eu-west-2"
project_name = "falke"
environment  = "prod"

# ECS resources
ecs_cpu    = 256  # 0.25 vCPU
ecs_memory = 512  # 512 MB

# === Trading ===
trading_mode  = "paper"
paper_balance = "500.0"

# === Tail Risk strategy ===
tail_risk_max_price             = "0.03"
tail_risk_bet_usd               = "5.0"
tail_risk_kelly_edge_multiplier = "2.0"
tail_risk_min_payout_multiplier = "15.0"
tail_risk_take_profit_fraction  = "0.0"
tail_risk_take_profit_pct       = "0.0"
tail_risk_stop_loss_pct         = "0.0"

# === Market filters ===
market_expiry_window_hours = "24"
min_liquidity_usd          = "1000.0"
ignored_topics             = "politics,weather"

# === Wallet / live trading ===
polygon_rpc_url         = "https://polygon-bor-rpc.publicnode.com"
process_usdc_allowances = "false"   # set true once for a new wallet, then back to false

# === Risk / engine ===
trade_poll_interval_sec  = "1"
max_bet_usd              = "50.0"
max_open_positions       = "100"
cooldown_sec             = "600"
pnl_notify_threshold_usd = "50.0"
budget_brake_pct         = "20.0"   # pause if lost 20% of starting balance
budget_brake_time_sec    = "7200"   # resume after 1 hour

# === Testing / parameter sweep ===
testing_mode            = "true"
tail_risk_max_price_min = "0.01"
tail_risk_max_price_max = "0.10"
tail_risk_bet_usd_min   = "1.0"
tail_risk_bet_usd_max   = "10.0"

# === Secrets (fill these in) ===
telegram_bot_token      = "YOUR_BOT_TOKEN_HERE"
allowed_phones          = "+43XXXXXXXXXX"
# wallet_private_key is set manually in AWS Secrets Manager — do not put it here
