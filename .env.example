# === Falke Trading Bot Configuration ===

# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper

# Paper trading initial balance (USD)
PAPER_BALANCE=500.0

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated phone numbers allowed to register (with country code)
ALLOWED_PHONES=+43xxxxxxxxxx

# === Polymarket ===
# Gamma API (public, no auth needed)
GAMMA_API_URL=https://gamma-api.polymarket.com
# CLOB API (requires wallet signature)
CLOB_API_URL=https://clob.polymarket.com

# === Wallet (for live trading only) ===
# WARNING: Keep this secret! In production, use AWS Secrets Manager instead.
WALLET_PRIVATE_KEY=
# Set PROCESS_USDC_ALLOWANCES=true in .env only when you need to set up allowances for a new wallet.
PROCESS_USDC_ALLOWANCES=false

# === Testing Mode ===
# Set to "true" to run 10×10×10 = 1000 parameter sweep portfolios in parallel.
# Use /test in Telegram to see the top-10 leaderboard.
TESTING_MODE=false

# Common parameters for all strategies (shared)
# Fixed bet size per MR/ML position in USD (shared)
TRADE_BET_USD=10.0

# === Strategy: ML Signal Filter (XGBoost on MR signals) ===
# Path to ONNX model file (relative to working dir, empty = disabled)
ML_MODEL_PATH=research/mr_classifier_xgboost.onnx
# Minimum win probability to take a ML-filtered trade (0.55 = 55%)
ML_WIN_PROB_THRESHOLD=0.67
# Minimum price % change pre-filter for ML scan
ML_REVERSION_THRESHOLD=0.70
# ONNX Runtime shared library path (points to Python venv's ORT)
ORT_DYLIB_PATH=/home/artem/work/public/falke/research/.venv/lib/python3.14/site-packages/onnxruntime/capi/libonnxruntime.so.1.24.4

# === Strategy: Mean Reversion (plan B) ===
# Minimum price % change to trigger a mean reversion signal (0.20 = 20%)
MEAN_REVERSION_THRESHOLD=0.10
# Fraction of budget allocated to plain MR (0.0 = ML only, 1.0 = MR only)
# Set to 0.0 to run ML strategy exclusively (recommended)
MEAN_REVERSION_BUDGET_PCT=0.25

# Testing sweep (MR threshold × bet grid)
MEAN_REVERSION_THRESHOLD_MIN=0.10
MEAN_REVERSION_THRESHOLD_MAX=0.90
TRADE_BET_USD_MIN=1.0
TRADE_BET_USD_MAX=10.0

# ML threshold sweep for testing
ML_TEST_THRESHOLD_MIN=0.50
ML_TEST_THRESHOLD_MAX=0.80

# === Market Filters ===
# ML strategy: trade markets expiring within N hours (longer window = more signals)
ML_MARKET_EXPIRY_WINDOW_HOURS=48.0
# MR strategy: trade markets expiring within N hours (0.5h = 30min, more volatile)
MR_MARKET_EXPIRY_WINDOW_HOURS=0.5
# Minimum liquidity in USD to consider a market for trading
MIN_LIQUIDITY_USD=1000.0
IGNORED_TOPICS=

# === Risk Management ===
TRADE_POLL_INTERVAL_SEC=1
MAX_BET_USD=50.0
MAX_OPEN_POSITIONS=100
COOLDOWN_SEC=600
PNL_NOTIFY_THRESHOLD_USD=50.0
# Circuit breaker: pause trading if portfolio loss exceeds this % of initial balance (0 = disabled)
BUDGET_BRAKE_PCT=20.0
# How long to pause trading when the brake fires (seconds), 0 - stop indefinitely until manual restart
BUDGET_BRAKE_TIME_SEC=3600

# === DynamoDB ===
AWS_REGION=eu-west-2
# Table prefix (tables: {prefix}-dev-users, {prefix}-dev-sessions, {prefix}-dev-trades)
DYNAMO_TABLE_PREFIX=falke
# Local DynamoDB endpoint (LocalStack). Remove or leave empty for real AWS.
DYNAMO_ENDPOINT=http://localhost:4567

# === Logging ===
RUST_LOG=falke=info,teloxide=warn
