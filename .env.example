# === Falke Trading Bot Configuration ===

# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper

# Paper trading initial balance (USD)
PAPER_BALANCE=1000.0

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated phone numbers allowed to register (with country code)
ALLOWED_PHONES=+43xxxxxxxxxx

# === Polymarket ===
# Gamma API (public, no auth needed)
GAMMA_API_URL=https://gamma-api.polymarket.com
# CLOB API (requires wallet signature)
CLOB_API_URL=https://clob.polymarket.com

# === Wallet (for live trading only) ===
# WARNING: Keep this secret! In production, use AWS Secrets Manager instead.
WALLET_PRIVATE_KEY=

# === Strategy Parameters ===
# Arbitrage
ARB_THRESHOLD=0.97
ARB_BUDGET_PCT=0.10

# Momentum
MOMENTUM_DERIVATIVE_THRESHOLD=0.30
MOMENTUM_WINDOW_SEC=300
MOMENTUM_BUDGET_PCT=0.25
MOMENTUM_POLL_INTERVAL_SEC=10

# Mean Reversion (fade price spikes)
MEAN_REVERSION_THRESHOLD=0.20
MEAN_REVERSION_BUDGET_PCT=0.25

# Tail Risk (buy cheap long-shot outcomes)
TAIL_RISK_MAX_PRICE=0.05
TAIL_RISK_BUDGET_PCT=0.20
TAIL_RISK_BET_USD=5.0

# Market filters
MARKET_EXPIRY_WINDOW_DAYS=1
MIN_LIQUIDITY_USD=1000.0

# Risk management
MAX_BET_USD=50.0
MAX_OPEN_POSITIONS=20
COOLDOWN_SEC=600
TAKE_PROFIT_PCT=10.0
STOP_LOSS_PCT=8.0
PNL_NOTIFY_THRESHOLD_USD=20.0

# === DynamoDB ===
AWS_REGION=eu-west-2
# Table prefix (tables: {prefix}-dev-users, {prefix}-dev-sessions, {prefix}-dev-trades)
DYNAMO_TABLE_PREFIX=falke
# Environment name used in table names (e.g. "dev" -> falke-dev-sessions)
ENVIRONMENT=dev
# Local DynamoDB endpoint (LocalStack). Remove or leave empty for real AWS.
DYNAMO_ENDPOINT=http://localhost:4567

# === Logging ===
RUST_LOG=falke=debug,teloxide=warn
